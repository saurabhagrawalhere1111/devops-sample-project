# Copy to .env for local development. NEVER commit a real .env.
# In the cluster these come from AWS Secrets Manager via External Secrets (Phase 5).

# --- Django ---
DJANGO_SECRET_KEY=change-me-locally
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOW_ALL=true
DJANGO_LOG_LEVEL=INFO

# --- Database (local docker-compose uses Postgres) ---
DB_ENGINE=postgres
DB_NAME=notesdb
DB_USER=notes
DB_PASSWORD=notes
DB_HOST=db
DB_PORT=5432
